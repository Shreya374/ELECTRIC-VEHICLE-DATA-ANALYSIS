      <column caption='% of BEV Vehicles' datatype='real' name='[Calculation_506655012313968642]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_506655012312686593]/[Calculation_886646230549815296]' />
      </column>
      <column caption='Total PHEV Vehicles' datatype='integer' name='[Calculation_506655012337246216]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF[Electric Vehicle Type] = &quot;Plug-in Hybrid Electric Vehicle (PHEV)&quot;&#13;&#10;THEN&#13;&#10;[DOL Vehicle ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='%of PHEV Vehicles' datatype='real' name='[Calculation_506655012340314121]' role='measure' type='quantitative'>
